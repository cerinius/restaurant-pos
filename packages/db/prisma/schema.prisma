// ==========================================
// SUPPORT — LIVE CHAT & VOICE
// ==========================================

model SupportTicket {
  id              String        @id @default(cuid())
  ticketNumber    Int           @default(autoincrement())
  restaurantId    String
  channel         TicketChannel
  status          TicketStatus  @default(OPEN)
  priority        String        @default("normal")
  subject         String?
  customerId      String?
  assignedAgentId String?
  source          String        @default("pos")
  openedAt        DateTime      @default(now())
  resolvedAt      DateTime?
  closedAt        DateTime?
  metadata        Json          @default("{}")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  restaurant    Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customer      SupportCustomer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignedAgent SupportAgent?     @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)
  conversation  SupportConversation?
  callLog       SupportCallLog?
  queueEvents   SupportQueueEvent[]

  @@index([restaurantId, status])
  @@index([restaurantId, channel])
  @@index([customerId])
  @@index([assignedAgentId])
  @@map("support_tickets")
}

model SupportAgent {
  id                  String         @id @default(cuid())
  restaurantId        String
  userId              String?
  fullName            String
  email               String
  presence            AgentPresence  @default(OFFLINE)
  maxConcurrentChats  Int            @default(3)
  isAvailable         Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  restaurant  Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tickets     SupportTicket[]
  messages    SupportMessage[]
  callLogs    SupportCallLog[]
  queueEvents SupportQueueEvent[]

  @@unique([restaurantId, email])
  @@index([restaurantId])
  @@map("support_agents")
}

model SupportCustomer {
  id          String   @id @default(cuid())
  restaurantId String
  displayName String?
  phone       String?
  email       String?
  externalRef String?
  createdAt   DateTime @default(now())

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tickets    SupportTicket[]
  messages   SupportMessage[]
  callLogs   SupportCallLog[]

  @@index([restaurantId])
  @@map("support_customers")
}

model SupportConversation {
  id        String               @id @default(cuid())
  ticketId  String               @unique
  status    ConversationStatus   @default(ACTIVE)
  startedAt DateTime             @default(now())
  endedAt   DateTime?
  createdAt DateTime             @default(now())

  ticket   SupportTicket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@map("support_conversations")
}

model SupportMessage {
  id               String            @id @default(cuid())
  conversationId   String
  senderType       MessageSenderType
  senderCustomerId String?
  senderAgentId    String?
  messageType      String            @default("text")
  body             String
  deliveredAt      DateTime?
  readAt           DateTime?
  clientMessageId  String?
  metadata         Json              @default("{}")
  createdAt        DateTime          @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  customer     SupportCustomer?    @relation(fields: [senderCustomerId], references: [id], onDelete: SetNull)
  agent        SupportAgent?       @relation(fields: [senderAgentId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@map("support_messages")
}

model SupportCallLog {
  id               String      @id @default(cuid())
  ticketId         String      @unique
  customerId       String?
  agentId          String?
  twilioCallSid    String?     @unique
  direction        CallDirection
  status           CallLogStatus @default(QUEUED)
  fromNumber       String?
  toNumber         String?
  startedAt        DateTime?
  answeredAt       DateTime?
  endedAt          DateTime?
  durationSeconds  Int         @default(0)
  queueWaitSeconds Int         @default(0)
  recordingUrl     String?
  hangupReason     String?
  metadata         Json        @default("{}")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  ticket   SupportTicket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  customer SupportCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  agent    SupportAgent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@index([status])
  @@map("support_call_logs")
}

model SupportQueueEvent {
  id        String   @id @default(cuid())
  ticketId  String
  eventType String
  agentId   String?
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  agent  SupportAgent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@map("support_queue_events")
}

// ── Support-specific enums ──────────────────────────────────

enum TicketChannel {
  CHAT
  CALL
  EMAIL
}

enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum MessageSenderType {
  CUSTOMER
  AGENT
  SYSTEM
}

enum ConversationStatus {
  ACTIVE
  ENDED
  ARCHIVED
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallLogStatus {
  QUEUED
  RINGING
  IN_PROGRESS
  COMPLETED
  BUSY
  FAILED
  NO_ANSWER
  CANCELED
}

enum AgentPresence {
  ONLINE
  AWAY
  OFFLINE
}
